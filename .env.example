# SAP ADT MCP Baglanti Bilgileri
# Bu dosyayi .env olarak kopyalayin ve gercek degerlerle doldurun.
# .env dosyasi git'e COMMIT EDILMEZ (.gitignore'da tanimli).

# SAP Sistem Baglantisi
# HTTP:  http://192.168.1.100:8000
# HTTPS: https://your-sap-host:44300
SAP_URL=http://your-sap-host:8000
SAP_CLIENT=100
SAP_USER=your_sap_user
SAP_PASSWORD=your_sap_password
SAP_LANGUAGE=EN

# HTTPS + self-signed sertifika varsa asagidaki satiri aktif edin
# NODE_TLS_REJECT_UNAUTHORIZED=0
